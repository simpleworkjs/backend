<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | SimpleWorkJS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://unpkg.com/mustache@4.2.0/mustache.min.js"></script>
  <script src="/lib/js/jq-repeat.js"></script>
  <script src="/lib/js/app.js"></script>
  <script src="/lib/js/app.model.js"></script>
  <script src="/lib/js/app.sync.js"></script>
  <script src="/lib/js/app.render.js"></script>
  <script src="/lib/js/app.custom.js"></script>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">SimpleWorkJS</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <% (navModels || []).forEach(function(m) { %>
            <li class="nav-item"><a class="nav-link" href="/<%= m.name %>/list"><%= m.display && m.display.name || m.name %></a></li>
          <% }); %>
          <li class="nav-item"><a class="nav-link" href="/custom/dashboard">Custom</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <%- body %>
  </main>

  <footer class="container py-3 text-muted border-top">
    <small>SimpleWorkJS beta — normal JS, normal HTML, just enough magic.</small>
  </footer>
</body>
</html>
